#!/usr/bin/env bash
# Interactive wrapper around generate.js. Prompts for a folder, title, and
# optional publish slug — then runs the generator with --pdf --pageless.
#
# Usage:
#   ./make-sheet                       # prompts for everything
#   ./make-sheet /path/to/videos       # skips the folder prompt
#
# Designed to be called from a macOS Shortcut, Finder Quick Action, or the
# Terminal directly.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

# Ensure Homebrew bins are available (Shortcuts/Quick Actions start with a
# minimal PATH).
export PATH="/opt/homebrew/bin:/usr/local/bin:$PATH"

# File to remember the last client name between runs
LAST_CLIENT_FILE="$SCRIPT_DIR/.last-client"
LAST_CLIENT=""
[[ -f "$LAST_CLIENT_FILE" ]] && LAST_CLIENT=$(cat "$LAST_CLIENT_FILE")

# ---- folder ----
FOLDER="${1:-}"
if [[ -z "$FOLDER" ]]; then
  FOLDER=$(osascript -e 'POSIX path of (choose folder with prompt "Choose a folder of videos")') || exit 1
  FOLDER="${FOLDER%/}"
fi

if [[ ! -d "$FOLDER" ]]; then
  osascript -e "display alert \"Not a folder\" message \"$FOLDER\" as critical"
  exit 1
fi

DEFAULT_TITLE=$(basename "$FOLDER")

# ---- clean mode? ----
# Clean mode hides title, metadata, info section, and footer — just the grid.
# When clean is chosen, skip the client/URL/notes prompts since they won't appear.
MODE=$(osascript <<OSA
set m to button returned of (display dialog "Sheet style:" with title "Make Contact Sheet" buttons {"Standard", "Clean (grid only)"} default button "Standard")
return m
OSA
) || exit 1

CLEAN=0
[[ "$MODE" == "Clean (grid only)" ]] && CLEAN=1

# ---- title ----
TITLE=$(osascript <<OSA
set t to text returned of (display dialog "Title for the contact sheet:" default answer "$DEFAULT_TITLE" with title "Make Contact Sheet")
return t
OSA
) || exit 1

# Metadata prompts only for Standard mode
CLIENT=""
VIDEO_URL=""
NOTES=""
if [[ "$CLEAN" == "0" ]]; then
  # ---- client ----
  CLIENT=$(osascript <<OSA
set c to text returned of (display dialog "Client name:" default answer "$LAST_CLIENT" with title "Make Contact Sheet")
return c
OSA
) || exit 1
  echo -n "$CLIENT" > "$LAST_CLIENT_FILE"

  # ---- video files URL ----
  VIDEO_URL=$(osascript <<OSA
set u to text returned of (display dialog "Video files URL (e.g. Frame.io link):" default answer "" with title "Make Contact Sheet")
return u
OSA
) || exit 1

  # ---- notes ----
  NOTES=$(osascript <<OSA
set n to text returned of (display dialog "Notes:" default answer "" with title "Make Contact Sheet")
return n
OSA
) || exit 1
fi

# ---- orientation ----
ORIENTATION=$(osascript <<OSA
set o to button returned of (display dialog "Layout orientation:" with title "Make Contact Sheet" buttons {"Horizontal", "Vertical"} default button "Horizontal")
return o
OSA
) || exit 1

# ---- publish slug (blank = local only) ----
DEFAULT_SLUG=$(echo "$TITLE" | tr '[:upper:]' '[:lower:]' | tr ' ' '-' | tr -cd 'a-z0-9-')
SLUG=$(osascript <<OSA
set s to text returned of (display dialog "Publish slug (leave blank for local-only):" default answer "$DEFAULT_SLUG" with title "Make Contact Sheet")
return s
OSA
) || exit 1

# Sanitize slug: lowercase, spaces → hyphens, strip anything weird
if [[ -n "$SLUG" ]]; then
  SLUG=$(echo "$SLUG" | tr '[:upper:]' '[:lower:]' | tr ' ' '-' | tr -cd 'a-z0-9-')
fi

ARGS=("$FOLDER" --title "$TITLE" --pdf --pageless)
[[ "$CLEAN" == "1" ]] && ARGS+=(--clean)
[[ -n "$CLIENT" ]]    && ARGS+=(--client "$CLIENT")
[[ -n "$VIDEO_URL" ]] && ARGS+=(--url "$VIDEO_URL")
[[ -n "$NOTES" ]]     && ARGS+=(--notes "$NOTES")
if [[ "$ORIENTATION" == "Vertical" ]]; then
  ARGS+=(--vertical)
fi
if [[ -n "$SLUG" ]]; then
  ARGS+=(--publish "$SLUG")
fi

echo "[make-sheet] node generate.js ${ARGS[*]}"
node generate.js "${ARGS[@]}"

# Open the outputs (filename comes from the title, sanitized)
SAFE_TITLE=$(echo "$TITLE" | tr -d '/\\:*?"<>|' | tr -s ' ')
OUT_HTML="$SCRIPT_DIR/output/$SAFE_TITLE.html"
OUT_PDF="$SCRIPT_DIR/output/$SAFE_TITLE.pdf"
[[ -f "$OUT_HTML" ]] && open "$OUT_HTML"
[[ -f "$OUT_PDF" ]]  && open "$OUT_PDF"

# If published, copy URL to clipboard
if [[ -n "$SLUG" ]]; then
  URL="https://c7sharp9.github.io/client-preview/$SLUG.html"
  echo -n "$URL" | pbcopy
  osascript -e "display notification \"URL copied to clipboard\" with title \"Published\" subtitle \"$URL\""
fi
