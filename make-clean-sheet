#!/usr/bin/env bash
# Interactive wrapper for a CLEAN contact sheet — no title, header, info
# section, or footer. Just the thumbnail grid. Ideal for embedding in a
# client dashboard iframe.
#
# Usage:
#   ./make-clean-sheet                       # prompts for everything
#   ./make-clean-sheet /path/to/videos       # skips the folder prompt
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

export PATH="/opt/homebrew/bin:/usr/local/bin:$PATH"

# ---- folder ----
FOLDER="${1:-}"
if [[ -z "$FOLDER" ]]; then
  FOLDER=$(osascript -e 'POSIX path of (choose folder with prompt "Choose a folder of videos (clean sheet)")') || exit 1
  FOLDER="${FOLDER%/}"
fi

if [[ ! -d "$FOLDER" ]]; then
  osascript -e "display alert \"Not a folder\" message \"$FOLDER\" as critical"
  exit 1
fi

DEFAULT_TITLE=$(basename "$FOLDER")

# ---- title (used for slug default + browser tab, but hidden on page) ----
TITLE=$(osascript <<OSA
set t to text returned of (display dialog "Title (used for slug / browser tab only — hidden on the page):" default answer "$DEFAULT_TITLE" with title "Make Clean Contact Sheet")
return t
OSA
) || exit 1

# ---- publish slug (blank = local only) ----
DEFAULT_SLUG=$(echo "$TITLE" | tr '[:upper:]' '[:lower:]' | tr ' ' '-' | tr -cd 'a-z0-9-')
SLUG=$(osascript <<OSA
set s to text returned of (display dialog "Publish slug (leave blank for local-only):" default answer "$DEFAULT_SLUG" with title "Make Clean Contact Sheet")
return s
OSA
) || exit 1

# Sanitize slug
if [[ -n "$SLUG" ]]; then
  SLUG=$(echo "$SLUG" | tr '[:upper:]' '[:lower:]' | tr ' ' '-' | tr -cd 'a-z0-9-')
fi

ARGS=("$FOLDER" --title "$TITLE" --clean --pdf --pageless)
if [[ -n "$SLUG" ]]; then
  ARGS+=(--publish "$SLUG")
fi

echo "[make-clean-sheet] node generate.js ${ARGS[*]}"
node generate.js "${ARGS[@]}"

# Open the outputs
OUT_HTML="$SCRIPT_DIR/output/$(basename "$FOLDER").html"
OUT_PDF="$SCRIPT_DIR/output/$(basename "$FOLDER").pdf"
[[ -f "$OUT_HTML" ]] && open "$OUT_HTML"
[[ -f "$OUT_PDF" ]]  && open "$OUT_PDF"

# If published, copy URL to clipboard
if [[ -n "$SLUG" ]]; then
  URL="https://c7sharp9.github.io/client-preview/$SLUG.html"
  echo -n "$URL" | pbcopy
  osascript -e "display notification \"URL copied to clipboard\" with title \"Published (clean)\" subtitle \"$URL\""
fi
